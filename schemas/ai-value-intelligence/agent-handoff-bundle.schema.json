{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fluencytracr.local/schemas/ai-value-intelligence/agent-handoff-bundle.schema.json",
  "title": "AI Value Agent Handoff Bundle",
  "description": "Docs-backed local schema for a governed bundle of AI Value specialist-agent handoffs from an executive operating packet. This is development infrastructure only, not a production agent runtime.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "bundle_id",
    "source_packet_ref",
    "workflow_family",
    "value_route",
    "handoffs",
    "ledger",
    "blocked_data_capture",
    "governance_boundaries",
    "feeds"
  ],
  "properties": {
    "schema_version": {
      "const": "FT_AI_VALUE_AGENT_HANDOFF_BUNDLE_2026_06"
    },
    "bundle_id": {
      "type": "string"
    },
    "source_packet_ref": {
      "type": "string"
    },
    "workflow_family": {
      "type": "string"
    },
    "value_route": {
      "type": "string"
    },
    "handoffs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./agent-handoff.schema.json"
      }
    },
    "ledger": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "scope_ref",
        "handoff_ref",
        "verification_refs",
        "required_caveats"
      ],
      "properties": {
        "schema_version": {
          "const": "AR_LEDGER_2026_05"
        },
        "scope_ref": {
          "type": "string"
        },
        "handoff_ref": {
          "type": "string"
        },
        "verification_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "required_caveats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "blocked_data_capture": {
      "type": "array",
      "items": {
        "enum": [
          "raw_prompt",
          "raw_response",
          "message_text",
          "file_content",
          "diff",
          "patch",
          "email",
          "user_id",
          "person_id",
          "customer_telemetry",
          "roi_calculation",
          "causality_claim",
          "individual_scoring"
        ]
      }
    },
    "governance_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "customer_telemetry",
        "production_agent_runtime",
        "autonomous_customer_action",
        "raw_prompt_or_response_storage",
        "direct_identifier_capture",
        "roi_calculation",
        "causality_claim",
        "individual_scoring",
        "customer_facing_economic_output"
      ],
      "properties": {
        "customer_telemetry": {
          "const": false
        },
        "production_agent_runtime": {
          "const": false
        },
        "autonomous_customer_action": {
          "const": false
        },
        "raw_prompt_or_response_storage": {
          "const": false
        },
        "direct_identifier_capture": {
          "const": false
        },
        "roi_calculation": {
          "const": false
        },
        "causality_claim": {
          "const": false
        },
        "individual_scoring": {
          "const": false
        },
        "customer_facing_economic_output": {
          "const": false
        }
      }
    },
    "feeds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_agent_run_ledger",
        "production_agent_runtime",
        "customer_telemetry"
      ],
      "properties": {
        "local_agent_run_ledger": {
          "type": "boolean"
        },
        "production_agent_runtime": {
          "const": false
        },
        "customer_telemetry": {
          "const": false
        }
      }
    }
  }
}
