{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fluencytracr.local/schemas/ai-value-intelligence/evidence-readiness.schema.json",
  "title": "AI Value Evidence Readiness",
  "description": "Docs-backed local schema for governed AI Value evidence readiness records. This is not a production API contract.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "readiness_id",
    "workflow_family",
    "value_route",
    "source_refs",
    "source_coverage",
    "readiness_checks",
    "decision",
    "decision_rationale",
    "next_actions",
    "blocked_claims",
    "governance_boundaries"
  ],
  "properties": {
    "schema_version": {
      "const": "FT_AI_VALUE_READINESS_2026_06"
    },
    "readiness_id": {
      "type": "string"
    },
    "workflow_family": {
      "type": "string"
    },
    "value_route": {
      "type": "string"
    },
    "source_refs": {
      "type": "object",
      "required": ["blueprint_id", "metrics_library_id", "scenario_id"],
      "properties": {
        "blueprint_id": { "type": "string" },
        "metrics_library_id": { "type": "string" },
        "scenario_id": { "type": "string" }
      }
    },
    "source_coverage": {
      "type": "object",
      "additionalProperties": false
    },
    "readiness_checks": {
      "type": "object",
      "additionalProperties": false
    },
    "decision": {
      "enum": [
        "READY_FOR_EXECUTIVE_VALIDATION",
        "HOLD_FOR_ASSUMPTIONS",
        "HOLD_FOR_SOURCE_COVERAGE",
        "HOLD_FOR_BASELINE",
        "STOP_FOR_GOVERNANCE_REVIEW"
      ]
    },
    "decision_rationale": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "blocked_claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "governance_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "production_connector": { "const": false },
        "dashboard": { "const": false },
        "realized_roi_calculation": { "const": false },
        "causality_claim": { "const": false },
        "individual_scoring": { "const": false },
        "hr_analytics": { "const": false },
        "runtime_service": { "const": false },
        "customer_facing_economic_output": { "const": false }
      }
    }
  }
}
