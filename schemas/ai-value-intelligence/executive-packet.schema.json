{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fluencytracr.local/schemas/ai-value-intelligence/executive-packet.schema.json",
  "title": "AI Value Executive Validation Packet",
  "description": "Docs-backed local schema for a governed AI Value executive validation packet. This is not customer-facing economic output.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "workflow_family",
    "workflow_name",
    "value_route",
    "decision",
    "claim_state",
    "customer_facing_economic_output",
    "source_refs",
    "sections"
  ],
  "properties": {
    "schema_version": {
      "const": "FT_AI_VALUE_EXECUTIVE_PACKET_2026_06"
    },
    "packet_id": { "type": "string" },
    "workflow_family": { "type": "string" },
    "workflow_name": { "type": "string" },
    "value_route": { "type": "string" },
    "decision": {
      "enum": [
        "READY_FOR_EXECUTIVE_VALIDATION",
        "HOLD_FOR_ASSUMPTIONS",
        "HOLD_FOR_SOURCE_COVERAGE",
        "HOLD_FOR_BASELINE",
        "STOP_FOR_GOVERNANCE_REVIEW"
      ]
    },
    "claim_state": {
      "enum": ["CAVEATED", "INTERNAL_ONLY", "MISSING", "BLOCKED"]
    },
    "customer_facing_economic_output": { "const": false },
    "source_refs": {
      "type": "object",
      "required": [
        "blueprint_id",
        "metrics_library_id",
        "scenario_id",
        "readiness_id",
        "claim_boundary_id"
      ],
      "properties": {
        "blueprint_id": { "type": "string" },
        "metrics_library_id": { "type": "string" },
        "scenario_id": { "type": "string" },
        "readiness_id": { "type": "string" },
        "claim_boundary_id": { "type": "string" },
        "roi_scenario_id": { "type": "string" },
        "ebita_bridge_id": { "type": "string" },
        "engagement_id": { "type": "string" },
        "fluency_baseline_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sections": {
      "type": "object",
      "required": [
        "workflow",
        "metrics",
        "scenario",
        "readiness",
        "claim_boundary",
        "next_actions"
      ],
      "properties": {
        "workflow": {
          "type": "object",
          "required": ["hypothesis", "current_state_steps", "future_state_steps"],
          "properties": {
            "hypothesis": { "type": "string" },
            "current_state_steps": {
              "type": "array",
              "items": { "type": "string" }
            },
            "future_state_steps": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "metric_id",
              "name",
              "value_route",
              "measurement_unit",
              "owner"
            ],
            "properties": {
              "metric_id": { "type": "string" },
              "name": { "type": "string" },
              "value_route": { "type": "string" },
              "measurement_unit": { "type": "string" },
              "owner": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "scenario": {
          "type": "object",
          "required": ["scenario_id", "bands", "output_units"],
          "properties": {
            "scenario_id": { "type": "string" },
            "bands": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["band", "interpretation", "included_metric_ids"],
                "properties": {
                  "band": { "type": "string" },
                  "interpretation": { "type": "string" },
                  "included_metric_ids": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "additionalProperties": false
              }
            },
            "output_units": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "readiness": {
          "type": "object",
          "required": ["decision", "checks", "rationale"],
          "properties": {
            "decision": { "type": "string" },
            "checks": {
              "type": "object",
              "required": [
                "workflow_state",
                "metric_state",
                "baseline_state",
                "assumption_state",
                "scenario_state",
                "governance_state"
              ],
              "properties": {
                "workflow_state": { "type": "string" },
                "metric_state": { "type": "string" },
                "baseline_state": { "type": "string" },
                "assumption_state": { "type": "string" },
                "scenario_state": { "type": "string" },
                "governance_state": { "type": "string" }
              },
              "additionalProperties": false
            },
            "rationale": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "claim_boundary": {
          "type": "object",
          "required": [
            "claim_state",
            "safe_claims",
            "caveated_claims",
            "blocked_claims",
            "required_caveats"
          ],
          "properties": {
            "claim_state": { "type": "string" },
            "safe_claims": {
              "type": "array",
              "items": { "type": "string" }
            },
            "caveated_claims": {
              "type": "array",
              "items": { "type": "string" }
            },
            "blocked_claims": {
              "type": "array",
              "items": { "type": "string" }
            },
            "required_caveats": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "next_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ebita_impact_summary": {
      "type": "object",
      "description": "Optional governed EBITA impact readout. It is a decision artifact, not an EBITA calculation or customer-facing economic output.",
      "required": [
        "status",
        "realized_ebita_claim_allowed",
        "customer_facing_allowed",
        "causality_claim_allowed",
        "primary_ebita_levers",
        "evidence_quality",
        "allowed_phrases",
        "required_caveats",
        "blocked_claims",
        "next_evidence_actions"
      ],
      "properties": {
        "status": {
          "enum": [
            "NO_FINANCIAL_TRANSLATION",
            "DIRECTIONAL_EBITA_BRIDGE",
            "MODELED_EBITA_SCENARIO",
            "FINANCE_VALIDATED_EBITA_CASE"
          ]
        },
        "realized_ebita_claim_allowed": { "const": false },
        "customer_facing_allowed": { "const": false },
        "causality_claim_allowed": { "const": false },
        "primary_ebita_levers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_quality": {
          "type": "object",
          "required": [
            "adoption_evidence",
            "workflow_evidence",
            "outcome_evidence",
            "financial_evidence",
            "overall_ebita_confidence"
          ],
          "properties": {
            "adoption_evidence": {
              "enum": ["MISSING", "BLOCKED", "SUPPRESSED", "DIRECTIONAL", "CAVEATED", "PRESENT", "SUPPORTED", "FINANCE_VALIDATED"]
            },
            "workflow_evidence": {
              "enum": ["MISSING", "BLOCKED", "SUPPRESSED", "DIRECTIONAL", "CAVEATED", "PRESENT", "SUPPORTED", "FINANCE_VALIDATED"]
            },
            "outcome_evidence": {
              "enum": ["MISSING", "BLOCKED", "SUPPRESSED", "DIRECTIONAL", "CAVEATED", "PRESENT", "SUPPORTED", "FINANCE_VALIDATED"]
            },
            "financial_evidence": {
              "enum": ["MISSING", "BLOCKED", "SUPPRESSED", "DIRECTIONAL", "CAVEATED", "PRESENT", "SUPPORTED", "FINANCE_VALIDATED"]
            },
            "overall_ebita_confidence": {
              "enum": ["MISSING", "BLOCKED", "SUPPRESSED", "DIRECTIONAL", "CAVEATED", "PRESENT", "SUPPORTED", "FINANCE_VALIDATED"]
            }
          },
          "additionalProperties": false
        },
        "allowed_phrases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_caveats": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocked_claims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_evidence_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
