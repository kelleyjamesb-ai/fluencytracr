{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fluencytracr.local/schemas/ai-value-intelligence/executive-packet.schema.json",
  "title": "AI Value Executive Validation Packet",
  "description": "Docs-backed local schema for a governed AI Value executive validation packet. This is not customer-facing economic output.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "packet_id",
    "workflow_family",
    "workflow_name",
    "value_route",
    "decision",
    "claim_state",
    "customer_facing_economic_output",
    "source_refs",
    "sections"
  ],
  "properties": {
    "schema_version": {
      "const": "FT_AI_VALUE_EXECUTIVE_PACKET_2026_06"
    },
    "packet_id": { "type": "string" },
    "workflow_family": { "type": "string" },
    "workflow_name": { "type": "string" },
    "value_route": { "type": "string" },
    "decision": {
      "enum": [
        "READY_FOR_EXECUTIVE_VALIDATION",
        "HOLD_FOR_ASSUMPTIONS",
        "HOLD_FOR_SOURCE_COVERAGE",
        "HOLD_FOR_BASELINE",
        "STOP_FOR_GOVERNANCE_REVIEW"
      ]
    },
    "claim_state": {
      "enum": ["CAVEATED", "INTERNAL_ONLY", "MISSING", "BLOCKED"]
    },
    "customer_facing_economic_output": { "const": false },
    "source_refs": {
      "type": "object",
      "required": [
        "blueprint_id",
        "metrics_library_id",
        "scenario_id",
        "readiness_id",
        "claim_boundary_id"
      ],
      "properties": {
        "blueprint_id": { "type": "string" },
        "metrics_library_id": { "type": "string" },
        "scenario_id": { "type": "string" },
        "readiness_id": { "type": "string" },
        "claim_boundary_id": { "type": "string" },
        "roi_scenario_id": { "type": "string" },
        "ebita_bridge_id": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "required": [
        "workflow",
        "metrics",
        "scenario",
        "readiness",
        "claim_boundary",
        "next_actions"
      ]
    },
    "ebita_impact_summary": {
      "type": "object",
      "description": "Optional governed EBITA impact readout. It is a decision artifact, not an EBITA calculation or customer-facing economic output.",
      "required": [
        "status",
        "realized_ebita_claim_allowed",
        "customer_facing_allowed",
        "causality_claim_allowed",
        "primary_ebita_levers",
        "evidence_quality",
        "allowed_phrases",
        "required_caveats",
        "blocked_claims",
        "next_evidence_actions"
      ],
      "properties": {
        "status": {
          "enum": [
            "NO_FINANCIAL_TRANSLATION",
            "DIRECTIONAL_EBITA_BRIDGE",
            "MODELED_EBITA_SCENARIO",
            "FINANCE_VALIDATED_EBITA_CASE",
            "CUSTOMER_FACING_APPROVED"
          ]
        },
        "realized_ebita_claim_allowed": { "type": "boolean" },
        "customer_facing_allowed": { "type": "boolean" },
        "causality_claim_allowed": { "type": "boolean" },
        "primary_ebita_levers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_quality": {
          "type": "object",
          "required": [
            "adoption_evidence",
            "workflow_evidence",
            "outcome_evidence",
            "financial_evidence",
            "overall_ebita_confidence"
          ],
          "properties": {
            "adoption_evidence": { "type": "string" },
            "workflow_evidence": { "type": "string" },
            "outcome_evidence": { "type": "string" },
            "financial_evidence": { "type": "string" },
            "overall_ebita_confidence": { "type": "string" }
          },
          "additionalProperties": false
        },
        "allowed_phrases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_caveats": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocked_claims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_evidence_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
