{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FluencyTracr V1 Evaluation Decision (Internal Only)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "FT_V1_2026_01"
    },
    "artifact_name": {
      "type": "string",
      "const": "FT_V1_EVALUATION_DECISION"
    },
    "org_id": {
      "type": "string",
      "minLength": 1
    },
    "function_id": {
      "type": "string",
      "minLength": 1
    },
    "role_class": {
      "type": "string",
      "minLength": 1
    },
    "window_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}__\\d{4}-\\d{2}-\\d{2}$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "SURFACE",
        "SUPPRESS"
      ]
    },
    "suppress_reason_code": {
      "type": "string",
      "enum": [
        "SUPP_INTERNAL_INVARIANT_FAIL",
        "SUPP_AMBIGUITY_PRESENT",
        "SUPP_SMALL_TEAM_LT_5",
        "SUPP_WINDOW_LT_60D",
        "SUPP_NOT_ADJACENT_WINDOWS",
        "SUPP_LT_2_BEHAVIOR_CLASSES",
        "SUPP_NO_QUALIFYING_EVIDENCE",
        "SUPP_SPARSE_DATA"
      ]
    }
  },
  "required": [
    "schema_version",
    "artifact_name",
    "org_id",
    "function_id",
    "role_class",
    "window_id",
    "decision"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "SUPPRESS"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "required": [
          "suppress_reason_code"
        ]
      },
      "else": {
        "not": {
          "required": [
            "suppress_reason_code"
          ]
        }
      }
    }
  ]
}
