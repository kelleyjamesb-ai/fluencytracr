{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FluencyTracr V1 Evaluation Decision (Internal Only)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "FT_V1_2026_01"
    },
    "artifact_name": {
      "type": "string",
      "const": "FT_V1_EVALUATION_DECISION"
    },
    "org_id": {
      "type": "string",
      "minLength": 1
    },
    "function_id": {
      "type": "string",
      "minLength": 1
    },
    "role_class": {
      "type": "string",
      "minLength": 1
    },
    "window_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}__\\d{4}-\\d{2}-\\d{2}$"
    },
    "decision": {
      "type": "string",
      "enum": ["SURFACE"]
    },
    "value_type": {
      "type": "string",
      "enum": [
        "ACCELERATION",
        "QUALITY_PREMIUM",
        "NET_NEW",
        "UNCLASSIFIED"
      ]
    },
    "evidence_grade": {
      "type": "string",
      "enum": [
        "OBJECTIVE",
        "CALIBRATED",
        "QUALITATIVE"
      ]
    }
  },
  "required": [
    "schema_version",
    "artifact_name",
    "org_id",
    "function_id",
    "role_class",
    "window_id",
    "decision",
    "value_type",
    "evidence_grade"
  ]
}
