    "validate:ai-value-metrics": "node scripts/validate_ai_value_metrics.mjs",
    "test:ai-value-metrics": "node --test scripts/validate_ai_value_metrics.test.mjs",
    "validate:ai-value-scenario": "node scripts/validate_ai_value_scenario.mjs",
