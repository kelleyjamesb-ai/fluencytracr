{
  "private": true,
  "workspaces": ["backend", "frontend", "shared", "packages/fluencytracr-mcp", "packages/glean-publisher", "integrations/openai-agents"],
  "scripts": {
    "agent:dev": "npm run build --workspace @learnaire/openai-agents-harness && npm run start --workspace @learnaire/openai-agents-harness --",
    "test:agentic-harness": "node --test scripts/agentic_harness_guard.test.mjs scripts/agentic_harness_ledger.test.mjs scripts/agentic_harness_replay.test.mjs",
    "glean:readiness": "npm run build --workspace shared && node scripts/generate_glean_readiness_map.mjs",
    "glean:readiness:sources": "npm run build --workspace shared && node scripts/generate_glean_readiness_from_sources.mjs",
    "validate:agents": "npm run build --workspace @learnaire/openai-agents-harness",
    "seed:lmsys": "node scripts/seed_lmsys.mjs",
    "seed:lmsys:sample": "node scripts/seed_lmsys_sample.mjs",
    "seed:lmsys:assurance": "node scripts/seed_lmsys_assurance.mjs",
    "verify:assurance": "node scripts/verify_lmsys_assurance.mjs",
    "test:seed": "npm run build --workspace shared && node --test scripts/lmsys_harness_selftest.mjs"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.2.0",
    "@types/express": "^4.17.21",
    "vitest": "^2.1.8"
  }
}
