# FluencyTracr Harness Configuration

# Storage path for batch state files
FLUENCYTRACR_DATA_PATH=data/batches

# Maximum retry attempts for failed steps
FLUENCYTRACR_MAX_RETRIES=3

# Lock timeout in seconds for concurrent access
FLUENCYTRACR_LOCK_TIMEOUT=30

# Archive completed batches after this many days
FLUENCYTRACR_ARCHIVE_AFTER_DAYS=30
