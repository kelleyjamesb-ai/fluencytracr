{
  "schema_version": "FT_AI_VALUE_DATA_BOUNDARY_ROI_EVIDENCE_2026_06",
  "contract_id": "data_boundary_customer_support_roi_evidence_v1",
  "purpose": "Define which organizational data may support AI value analysis, where sensitive data may be used upstream, and which aggregate evidence may cross into FluencyTracr.",
  "metric_pyramid": {
    "north_star_metric": {
      "name": "Validated AI Value Movement",
      "definition": "Share of prioritized workflow slices where AI capability, VBD movement, customer-owned outcome movement, and evidence quality support governed value language.",
      "required_inputs": [
        "ai_fluency_baseline_or_followup",
        "vbd_movement",
        "function_outcome_metric",
        "accepted_or_caveated_customer_outcome_evidence",
        "claim_governance"
      ]
    },
    "supporting_metrics": [
      {
        "name": "AI Work Integration / VBD",
        "definition": "Velocity, Breadth, and Depth show whether AI is becoming real work in approved workflow slices."
      },
      {
        "name": "AI Capability Growth",
        "definition": "Aggregate AI Fluency and behavioral proxies show whether people are becoming more capable with AI over time."
      }
    ]
  },
  "vbd_definitions": {
    "velocity": {
      "definition": "speed_to_adoption",
      "plain_language": "How quickly a function or workflow moves from AI availability to active, repeated use.",
      "allowed_aggregate_fields": [
        "time_to_first_meaningful_use_days",
        "time_to_repeated_use_days",
        "adoption_curve_slope",
        "active_share_day_30",
        "active_share_day_60",
        "active_share_day_90"
      ]
    },
    "breadth": {
      "definition": "spread_across_org_functions_workflows",
      "plain_language": "How widely AI spreads across approved functions, roles, workflows, regions, or cohorts.",
      "allowed_aggregate_fields": [
        "function_coverage_share",
        "workflow_coverage_share",
        "role_family_coverage_share",
        "region_coverage_share",
        "priority_use_case_coverage_share"
      ]
    },
    "depth": {
      "definition": "aggregate_ai_tool_surface_repertoire",
      "plain_language": "How many AI tools or surfaces people use, exposed only as aggregate distributions.",
      "allowed_aggregate_fields": [
        "ai_surface_count_p50",
        "ai_surface_count_p90",
        "multi_surface_share",
        "advanced_surface_share",
        "search_assistant_skills_agents_mcp_coverage"
      ]
    }
  },
  "boundary_model": {
    "source_system_zone": "Customer-owned systems may contain raw operational, communication, HRIS, finance, and workflow data under customer policy.",
    "transformation_boundary": "Customer or Glean-approved transformer may join, classify, dedupe, and aggregate sensitive data before export.",
    "fluencytracr_boundary": {
      "aggregate_only": true,
      "raw_source_rows_allowed": false,
      "direct_identifiers_allowed": false,
      "raw_content_allowed": false
    }
  },
