{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fluencytracr/contracts/evidence-bundle/v1/evidence-bundle.schema.json",
  "title": "EvidenceBundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "org_id",
    "window",
    "generated_at",
    "suppression",
    "coverage",
    "exposure",
    "calibration",
    "fragility",
    "learning"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evidence_bundle.v1"
    },
    "org_id": {
      "type": "string",
      "minLength": 1
    },
    "window": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "30d",
        "60d",
        "90d",
        "180d",
        "360d",
        "3m",
        "6m",
        "12m"
      ]    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "suppression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["k_min", "suppression_applied", "suppression_reasons"],
      "properties": {
        "k_min": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "suppression_applied": {
          "type": "boolean"
        },
        "suppression_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "k_min_threshold",
              "irreducible_aggregation",
              "exec_mode_no_org_structure_slice",
              "insufficient_population",
              "privacy_policy_guardrail"
            ]
          },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "suppression_applied": { "const": true }
            },
            "required": ["suppression_applied"]
          },
          "then": {
            "properties": {
              "suppression_reasons": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrumented_sources", "missing_sources", "coverage_notes"],
      "properties": {
        "instrumented_sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "missing_sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "coverage_notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "exposure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shadow_ai", "unsanctioned_tool_class"],
      "properties": {
        "shadow_ai": { "$ref": "#/$defs/signal_observation" },
        "unsanctioned_tool_class": { "$ref": "#/$defs/signal_observation" }
      }
    },
    "calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verification_presence",
        "recovery_presence",
        "escalation_to_safe_path_presence"
      ],
      "properties": {
        "verification_presence": { "$ref": "#/$defs/signal_observation" },
        "recovery_presence": { "$ref": "#/$defs/signal_observation" },
        "escalation_to_safe_path_presence": { "$ref": "#/$defs/signal_observation" }
      }
    },
    "fragility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "friction_loops_elevated",
        "rapid_abandonment_elevated",
        "blind_acceptance_risk_elevated"
      ],
      "properties": {
        "friction_loops_elevated": { "$ref": "#/$defs/signal_observation" },
        "rapid_abandonment_elevated": { "$ref": "#/$defs/signal_observation" },
        "blind_acceptance_risk_elevated": { "$ref": "#/$defs/signal_observation" }
      }
    },
    "learning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trend_direction"],
      "properties": {
        "trend_direction": {
          "type": "string",
          "enum": ["improving", "stable", "degrading", "suppressed", "not_computed"]
        }
      }
    },
    "forwarded_distribution": {
      "$ref": "#/$defs/forwarded_distribution"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "suppression": {
            "properties": {
              "suppression_applied": { "const": true }
            },
            "required": ["suppression_applied"]
          }
        },
        "required": ["suppression"]
      },
      "then": {
        "not": {
          "required": ["forwarded_distribution"]
        }
      }
    }
  ],
  "$defs": {
    "evidence_status": {
      "type": "string",
      "enum": ["present", "not_present", "suppressed", "not_computed"]
    },
    "distribution_value": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p10", "p50", "p90", "p99"],
      "properties": {
        "p10": { "type": "number", "minimum": 0 },
        "p50": { "type": "number", "minimum": 0 },
        "p90": { "type": "number", "minimum": 0 },
        "p99": { "type": "number", "minimum": 0 }
      }
    },
    "quality_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completion_rate",
        "error_rate",
        "abandonment_rate",
        "recovery_rate",
        "verification_rate",
        "p50_latency_ms",
        "p95_latency_ms"
      ],
      "properties": {
        "completion_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "error_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "abandonment_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "recovery_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "verification_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "p50_latency_ms": { "type": "integer", "minimum": 0 },
        "p95_latency_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "forwarded_distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "source_schema_version",
        "cohort_id",
        "workflow_id",
        "jbtd_id",
        "persona_id",
        "window_start",
        "window_end",
        "window_days",
        "cohort_size",
        "ambiguity_rate",
        "calibration_id",
        "surface_taxonomy_ids",
        "velocity",
        "quality_signals",
        "distribution_moments",
        "baseline_stable",
        "value_type",
        "evidence_grade",
        "privacy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "FT_V3_FORWARDED_DISTRIBUTION_2026_06"
        },
        "source_schema_version": {
          "type": "string",
          "const": "FT_V3_2026_05"
        },
        "cohort_id": { "type": "string", "minLength": 1, "maxLength": 180, "pattern": "^[A-Za-z0-9:_-]+$" },
        "workflow_id": { "type": "string", "minLength": 1, "maxLength": 180, "pattern": "^[A-Za-z0-9:_-]+$" },
        "jbtd_id": { "type": ["string", "null"] },
        "persona_id": { "type": ["string", "null"] },
        "window_start": { "type": "string", "format": "date-time" },
        "window_end": { "type": "string", "format": "date-time" },
        "window_days": { "type": "integer", "minimum": 0 },
        "cohort_size": { "type": "integer", "minimum": 5 },
        "ambiguity_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "calibration_id": { "type": "string", "minLength": 1, "maxLength": 180, "pattern": "^[A-Za-z0-9:_-]+$" },
        "surface_taxonomy_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 180, "pattern": "^[A-Za-z0-9:_-]+$" },
          "uniqueItems": true
        },
        "velocity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["frequency", "engagement", "breadth"],
          "properties": {
            "frequency": { "$ref": "#/$defs/distribution_value" },
            "engagement": { "$ref": "#/$defs/distribution_value" },
            "breadth": { "$ref": "#/$defs/distribution_value" }
          }
        },
        "quality_signals": { "$ref": "#/$defs/quality_signals" },
        "distribution_moments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["frequency_mean", "engagement_mean", "breadth_mean"],
          "properties": {
            "frequency_mean": { "type": "number", "minimum": 0 },
            "engagement_mean": { "type": "number", "minimum": 0 },
            "breadth_mean": { "type": "number", "minimum": 0 }
          }
        },
        "baseline_stable": { "type": "boolean" },
        "value_type": {
          "type": "string",
          "enum": ["ACCELERATION", "QUALITY_PREMIUM", "NET_NEW", "UNCLASSIFIED"]
        },
        "evidence_grade": {
          "type": "string",
          "enum": ["OBJECTIVE", "CALIBRATED", "QUALITATIVE"]
        },
        "privacy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["aggregate_only", "person_level_fields_included"],
          "properties": {
            "aggregate_only": { "type": "boolean", "const": true },
            "person_level_fields_included": { "type": "boolean", "const": false }
          }
        }
      }
    },
    "bounded_aggregates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sample_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "numerator": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "denominator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        }
      }
    },
    "signal_observation": {
      "anyOf": [
        { "$ref": "#/$defs/evidence_status" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "$ref": "#/$defs/evidence_status" },
            "aggregates": { "$ref": "#/$defs/bounded_aggregates" }
          }
        }
      ]
    }
  }
}
