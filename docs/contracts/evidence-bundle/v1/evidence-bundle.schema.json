{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fluencytracr/contracts/evidence-bundle/v1/evidence-bundle.schema.json",
  "title": "EvidenceBundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "org_id",
    "window",
    "generated_at",
    "suppression",
    "coverage",
    "exposure",
    "calibration",
    "fragility",
    "learning"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evidence_bundle.v1"
    },
    "org_id": {
      "type": "string",
      "minLength": 1
    },
    "window": {
      "type": "string",
<<<<<<< HEAD
