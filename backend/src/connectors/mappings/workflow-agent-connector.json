{
  "connector_metadata": {
    "connector_name": "workflow-agent-connector",
    "connector_version": "1.0.0",
    "vendor": "example-workflow-vendor",
    "tool_class": "workflow_automation"
  },
  "signal_mappings": [
    {
      "external_event_type": "workflow.agent.invoked",
      "internal_signal_name": "invoke_ai",
      "requires_side_effect": false,
      "validation_rules": [
        {
          "rule_type": "field_exists",
          "field_path": "workflow_id"
        },
        {
          "rule_type": "field_exists",
          "field_path": "agent_type"
        }
      ],
      "metadata_extraction": {
        "is_cross_system": "workflow.is_cross_system"
      }
    },
    {
      "external_event_type": "workflow.action.completed",
      "internal_signal_name": "delegate_to_agent",
      "requires_side_effect": true,
      "validation_rules": [
        {
          "rule_type": "field_equals",
          "field_path": "action.status",
          "expected_value": "completed"
        },
        {
          "rule_type": "field_exists",
          "field_path": "action.external_effect"
        }
      ],
      "metadata_extraction": {
        "external_side_effect": "action.external_effect",
        "is_cross_system": "action.is_cross_system",
        "requires_approval": "action.required_approval"
      }
    },
    {
      "external_event_type": "workflow.agent.stopped",
      "internal_signal_name": "revoke_agent",
      "requires_side_effect": false,
      "validation_rules": [
        {
          "rule_type": "field_equals",
          "field_path": "stop_reason",
          "expected_value": "user_cancelled"
        }
      ]
    },
    {
      "external_event_type": "workflow.parameters.updated",
      "internal_signal_name": "refine_request",
      "requires_side_effect": false,
      "validation_rules": [
        {
          "rule_type": "field_exists",
          "field_path": "parameter_changes"
        },
        {
          "rule_type": "field_equals",
          "field_path": "updated_by",
          "expected_value": "user"
        }
      ]
    },
    {
      "external_event_type": "workflow.result.approved",
      "internal_signal_name": "accept_output",
      "requires_side_effect": false,
      "validation_rules": [
        {
          "rule_type": "field_equals",
          "field_path": "approval.status",
          "expected_value": "approved"
        }
      ],
      "metadata_extraction": {
        "has_human_review": "approval.human_reviewed",
        "requires_approval": "approval.required"
      }
    },
    {
      "external_event_type": "workflow.retry.triggered",
      "internal_signal_name": "retry_after_mismatch",
      "requires_side_effect": false,
      "validation_rules": [
        {
          "rule_type": "field_exists",
          "field_path": "retry_trigger"
        },
        {
          "rule_type": "field_matches",
          "field_path": "retry_trigger",
          "pattern": "(error|failure|mismatch)"
        }
      ]
    },
    {
      "external_event_type": "workflow.manual.takeover",
      "internal_signal_name": "override_to_manual",
      "requires_side_effect": false,
      "validation_rules": [
        {
          "rule_type": "field_equals",
          "field_path": "takeover.type",
          "expected_value": "manual_intervention"
        }
      ]
    }
  ],
  "forbidden_fields": [
    {
      "field_name": "prompt_content",
      "reason": "Privacy: Never collect prompt text"
    },
    {
      "field_name": "output_content",
      "reason": "Privacy: Never collect output text"
    },
    {
      "field_name": "message_text",
      "reason": "Privacy: Never collect message content"
    },
    {
      "field_name": "keystrokes",
      "reason": "Privacy: Never collect keystroke data"
    },
    {
      "field_name": "file_names",
      "reason": "Privacy: Never collect file names"
    },
    {
      "field_name": "raw_logs",
      "reason": "Privacy: Never collect raw logs"
    }
  ]
}
