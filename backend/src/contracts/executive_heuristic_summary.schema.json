{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "executive_heuristic_summary.schema.json",
  "title": "ExecutiveHeuristicSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "org_id",
    "window",
    "operational_telemetry_index"
  ],
  "properties": {
    "org_id": { "type": "string" },
    "window": { "type": "string", "enum": ["30d", "60d"] },
    "operational_telemetry_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "confidence",
        "components",
        "does_not_mean",
        "inference_version",
        "parameter_hash",
        "generated_at"
      ],
      "properties": {
        "value": { "type": "number" },
        "confidence": { "type": "number" },
        "components": {
          "type": "object",
          "additionalProperties": false,
          "required": ["workflow_coverage", "pattern_confidence"],
          "properties": {
            "workflow_coverage": { "type": "number" },
            "pattern_confidence": { "type": "number" }
          }
        },
        "does_not_mean": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "inference_version": { "type": "string" },
        "parameter_hash": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
