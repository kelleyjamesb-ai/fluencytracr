{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pattern_inference_record.schema.json",
  "title": "PatternInferenceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scope_key",
    "scope_type",
    "pattern"
  ],
  "properties": {
    "scope_key": { "type": "string" },
    "scope_type": {
      "type": "string",
      "enum": ["WORKFLOW_ROLE_RISK", "WORKFLOW_RISK", "ROLE_RISK"]
    },
    "pattern": {
      "type": "string",
      "enum": [
        "CALIBRATED_FLUENCY",
        "BLIND_EFFICIENCY",
        "RECOVERY_MATURITY",
        "FRICTION_LOOP",
        "UNDERTRUST_AVOIDANCE"
      ]
    }
  }
}
