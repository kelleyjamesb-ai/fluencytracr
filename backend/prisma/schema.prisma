generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  teams     Team[]
}

model Team {
  id             String        @id @default(uuid())
  name           String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime      @default(now())
  fluencyScores  FluencyScore[]
}

model FluencyScore {
  id             String   @id @default(uuid())
  organizationId String
  team           Team?    @relation(fields: [teamId], references: [id])
  teamId         String?
  day            DateTime
  score          Float
  coverage       Float
  depth          Float
  judgment       Float
  velocity       Float
  dataComplete   Boolean
  createdAt      DateTime @default(now())

  @@index([organizationId, day])
}

// Audit logging is implemented via append-only audit_log table and pg driver.
// This Prisma model is NOT authoritative for audit writes. See backend/src/audit/.
model AuditEvent {
  id        String   @id @default(uuid())
  orgId     String
  seq       Int
  actorSub  String
  actorRole String
  eventType String
  metadata  Json
  prevHash  String
  hash      String
  createdAt DateTime @default(now())

  @@unique([orgId, seq])
}

model FluencyEventIngest {
  event_id       String   @id
  received_at    DateTime @default(now())
  schema_version String
  payload        Json
}
