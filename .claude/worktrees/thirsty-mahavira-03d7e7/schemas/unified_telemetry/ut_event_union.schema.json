{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fluencytracr.local/schemas/unified_telemetry/ut_event_union.schema.json",
  "title": "Unified telemetry event (union)",
  "description": "Cross-surface append-only behavioral telemetry. No raw content fields. See docs/contracts/unified-telemetry/README.md.",
  "oneOf": [
    { "$ref": "#/$defs/humanInteractionEvent" },
    { "$ref": "#/$defs/agentExecutionEvent" },
    { "$ref": "#/$defs/controlSecurityEvent" },
    { "$ref": "#/$defs/outcomeEvent" }
  ],
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "const": "UT_2026_04"
    },
    "eventCategory": {
      "type": "string",
      "enum": [
        "HUMAN_INTERACTION",
        "AGENT_EXECUTION",
        "CONTROL_SECURITY",
        "OUTCOME"
      ]
    },
    "ingressSurface": {
      "type": "string",
      "enum": ["CHAT", "AGENT_RUNTIME", "API", "IDE", "ASSISTANT", "SEARCH"]
    },
    "traceAxis": {
      "type": "string",
      "enum": ["iteration", "override", "recovery", "resolution"]
    },
    "ambiguityReasonCode": {
      "type": "string",
      "enum": [
        "AMB_SCHEMA_MISSING_REQUIRED",
        "AMB_SCHEMA_INVALID_TYPE",
        "AMB_SCHEMA_OUT_OF_RANGE",
        "AMB_TEMPORAL_WINDOW_UNKNOWN",
        "AMB_TEMPORAL_EVENT_OUTSIDE_WINDOW",
        "AMB_EVIDENCE_CONFLICT",
        "AMB_EVIDENCE_INSUFFICIENT",
        "AMB_SOURCE_UNTRUSTED",
        "AMB_TOOL_SURFACE_UNKNOWN",
        "AMB_CROSS_SURFACE_UNKNOWN"
      ]
    },
    "envelopeCore": {
      "type": "object",
      "properties": {
        "schema_version": { "$ref": "#/$defs/schemaVersion" },
        "event_id": { "type": "string", "format": "uuid" },
        "event_name": { "type": "string", "minLength": 8, "pattern": "^UT\\.[A-Z]+\\.[A-Z0-9_]+\\.V[0-9]+$" },
        "event_category": { "$ref": "#/$defs/eventCategory" },
        "org_id": { "type": "string", "minLength": 1 },
        "function_id": { "type": "string", "minLength": 1 },
        "role_class": { "type": "string", "minLength": 1 },
        "ingress_surface": { "$ref": "#/$defs/ingressSurface" },
        "event_timestamp": { "type": "string", "format": "date-time" },
        "window_id": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}__\\d{4}-\\d{2}-\\d{2}$"
        },
        "trace_axes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/traceAxis" }
        },
        "ambiguity_flag": { "type": "boolean" },
        "ambiguity_reason_code": { "$ref": "#/$defs/ambiguityReasonCode" },
        "correlation_id": { "type": "string", "minLength": 4 },
        "causation_event_id": { "type": "string", "format": "uuid" },
        "sequence_no": { "type": "integer", "minimum": 0 },
        "workflow_id": { "type": "string", "minLength": 1 },
        "emitter_version": { "type": "string", "minLength": 1 }
      },
      "required": [
        "schema_version",
        "event_id",
        "event_name",
        "event_category",
        "org_id",
        "function_id",
        "role_class",
        "ingress_surface",
        "event_timestamp",
        "window_id",
        "trace_axes",
        "ambiguity_flag",
        "correlation_id"
      ]
    },
    "ambiguityConditional": {
      "type": "object",
      "allOf": [
        {
          "if": {
            "properties": { "ambiguity_flag": { "const": true } },
            "required": ["ambiguity_flag"]
          },
          "then": { "required": ["ambiguity_reason_code"] }
        },
        {
          "if": {
            "properties": { "ambiguity_flag": { "const": false } },
            "required": ["ambiguity_flag"]
          },
          "then": { "not": { "required": ["ambiguity_reason_code"] } }
        }
      ]
    },
    "humanPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interaction_kind": {
          "type": "string",
          "enum": ["DISPOSITION", "VERIFICATION", "HANDOFF", "OTHER"]
        },
        "disposition": {
          "type": "string",
          "enum": ["ACCEPT", "EDIT", "REJECT", "ABANDON"]
        },
        "edit_magnitude_bucket": {
          "type": "string",
          "enum": ["NONE", "LIGHT", "HEAVY"]
        },
        "verification_requested": { "type": "boolean" },
        "override_layer": {
          "type": "string",
          "enum": ["HUMAN", "POLICY", "SYSTEM"]
        }
      }
    },
    "agentPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_run_id", "step_index", "tool_class", "attempt_outcome", "latency_ms"],
      "properties": {
        "agent_run_id": { "type": "string", "minLength": 1 },
        "step_index": { "type": "integer", "minimum": 0 },
        "tool_class": {
          "type": "string",
          "enum": ["RETRIEVAL", "TOOL_ACTION", "REASONING_PLAN", "DELEGATION", "OTHER"]
        },
        "attempt_outcome": {
          "type": "string",
          "enum": ["SUCCESS", "FAIL", "SKIPPED"]
        },
        "latency_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "controlPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control_action", "policy_rule_class", "risk_bucket"],
      "properties": {
        "control_action": {
          "type": "string",
          "enum": ["ALLOW", "DENY", "RATE_LIMIT", "QUARANTINE", "AUDIT_ONLY"]
        },
        "policy_rule_class": {
          "type": "string",
          "enum": [
            "DATA_CLASSIFICATION",
            "ACCESS_CONTROL",
            "RATE",
            "CONTENT_POLICY",
            "TOOL_ALLOWLIST",
            "OTHER"
          ]
        },
        "risk_bucket": {
          "type": "string",
          "enum": ["NONE", "LOW", "MEDIUM", "HIGH"]
        }
      }
    },
    "outcomePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_status", "resolution_bucket", "escalation_triggered"],
      "properties": {
        "outcome_status": {
          "type": "string",
          "enum": ["COMPLETED", "FAILED", "ABANDONED", "SUPPRESSED", "ESCALATED"]
        },
        "resolution_bucket": {
          "type": "string",
          "enum": [
            "SUCCESS",
            "USER_ABORT",
            "POLICY_BLOCK",
            "SYSTEM_ERROR",
            "INSUFFICIENT_EVIDENCE",
            "OTHER"
          ]
        },
        "escalation_triggered": { "type": "boolean" }
      }
    },
    "humanInteractionEvent": {
      "allOf": [
        { "$ref": "#/$defs/envelopeCore" },
        { "$ref": "#/$defs/ambiguityConditional" },
        {
          "type": "object",
          "properties": {
            "event_category": { "const": "HUMAN_INTERACTION" },
            "event_name": {
              "type": "string",
              "enum": [
                "UT.HUMAN.DISPOSITION_RECORDED.V1",
                "UT.HUMAN.VERIFICATION_SIGNAL_RECORDED.V1",
                "UT.HUMAN.HANDOFF_RECORDED.V1"
              ]
            },
            "payload": { "$ref": "#/$defs/humanPayload" }
          },
          "required": ["event_category", "event_name", "payload"]
        }
      ]
    },
    "agentExecutionEvent": {
      "allOf": [
        { "$ref": "#/$defs/envelopeCore" },
        { "$ref": "#/$defs/ambiguityConditional" },
        {
          "type": "object",
          "properties": {
            "event_category": { "const": "AGENT_EXECUTION" },
            "event_name": {
              "type": "string",
              "enum": [
                "UT.AGENT.TOOL_STEP_RECORDED.V1",
                "UT.AGENT.RUN_BOUNDARY_RECORDED.V1"
              ]
            },
            "payload": { "$ref": "#/$defs/agentPayload" }
          },
          "required": ["event_category", "event_name", "payload"]
        }
      ]
    },
    "controlSecurityEvent": {
      "allOf": [
        { "$ref": "#/$defs/envelopeCore" },
        { "$ref": "#/$defs/ambiguityConditional" },
        {
          "type": "object",
          "properties": {
            "event_category": { "const": "CONTROL_SECURITY" },
            "event_name": {
              "type": "string",
              "enum": ["UT.CONTROL.POLICY_DECISION_RECORDED.V1"]
            },
            "payload": { "$ref": "#/$defs/controlPayload" }
          },
          "required": ["event_category", "event_name", "payload"]
        }
      ]
    },
    "outcomeEvent": {
      "allOf": [
        { "$ref": "#/$defs/envelopeCore" },
        { "$ref": "#/$defs/ambiguityConditional" },
        {
          "type": "object",
          "properties": {
            "event_category": { "const": "OUTCOME" },
            "event_name": {
              "type": "string",
              "enum": ["UT.OUTCOME.WORK_UNIT_RESOLVED.V1"]
            },
            "payload": { "$ref": "#/$defs/outcomePayload" }
          },
          "required": ["event_category", "event_name", "payload"]
        }
      ]
    }
  }
}
