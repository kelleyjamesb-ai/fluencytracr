{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "judgment_event.schema.json",
  "title": "JudgmentEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "schema_version",
    "source_system",
    "workflow_id",
    "role_context",
    "workflow_risk_level",
    "surface_type",
    "event_type",
    "human_action_timestamp",
    "latency_bucket"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "schema_version": { "type": "string" },
    "source_system": { "type": "string", "enum": ["legacy_fluency"] },
    "workflow_id": { "type": "string" },
    "role_context": { "type": "string", "enum": ["EXEC", "MANAGER", "IC", "UNKNOWN"] },
    "workflow_risk_level": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
    "surface_type": { "type": "string", "enum": ["CHAT", "DOC_BLOCK", "CODE_BLOCK", "SUMMARY"] },
    "event_type": { "type": "string", "enum": ["ACCEPT", "EDIT", "REJECT", "ABANDON", "OVERRIDE"] },
    "human_action_timestamp": { "type": "string", "format": "date-time" },
    "latency_bucket": { "type": "string", "enum": ["IMMEDIATE", "SHORT_DELAY", "LONG_DELAY"] }
  }
}
