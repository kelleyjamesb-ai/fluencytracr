# Backend API base URL.
# Production: set to your deployed backend host (no trailing slash).
#   Example: VITE_API_BASE_URL=https://your-backend.onrender.com
# Local dev: leave empty – the Vite dev-server proxy routes /api, /auth,
#   /health and /orgs to http://localhost:4000 automatically.
VITE_API_BASE_URL=
