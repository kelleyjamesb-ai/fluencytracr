{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace frontend || npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://learn-air-engable-tool-backend.vercel.app/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://learn-air-engable-tool-backend.vercel.app/auth/:path*"
    },
    {
      "source": "/health",
      "destination": "https://learn-air-engable-tool-backend.vercel.app/health"
    },
    {
      "source": "/orgs/:path*",
      "destination": "https://learn-air-engable-tool-backend.vercel.app/orgs/:path*"
    },
    {
      "source": "/((?!api(?:/|$)|auth(?:/|$)|health(?:/|$)|orgs(?:/|$)|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
